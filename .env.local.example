# ─── Firebase ────────────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps → Web App → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Google Maps ──────────────────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API, Directions API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Google Maps Map ID (for Advanced Markers) ────────────────────────────────
# Get from: Google Cloud Console → Google Maps Platform → Map Management
NEXT_PUBLIC_GOOGLE_MAP_ID=your_map_id_here

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production: NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
